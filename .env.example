# OpenRouter key — required. Used for both the Researcher and Drafter models.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Tavily search key — optional but recommended for enterprise research.
# When set, the Researcher uses Tavily instead of DuckDuckGo — cleaner
# results and fewer rate limits. Free tier is 1000 searches/month.
# Sign up: https://tavily.com
# Leave blank to fall back to DuckDuckGo.
TAVILY_API_KEY=
