# OpenRouter key — required. Used for both the Researcher and Drafter models.
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Tavily search key — optional but recommended for enterprise research.
# When set, the Researcher uses Tavily instead of DuckDuckGo — cleaner
# results and fewer rate limits. Free tier is 1000 searches/month.
# Sign up: https://tavily.com
# Leave blank to fall back to DuckDuckGo.
TAVILY_API_KEY=

# ZoomInfo API key — optional, enterprise-only. If set, the Targeter
# uses ZoomInfo to enrich decision-maker contacts (name, title, email,
# LinkedIn URL). Requires a paid ZoomInfo subscription.
ZOOMINFO_API_KEY=

# Apollo.io API key — optional, self-serve. If set (and ZoomInfo is not),
# the Targeter uses Apollo to enrich decision-maker contacts. Free tier
# is 50 API calls/month. Sign up: https://apollo.io
# Without ZoomInfo or Apollo, the Targeter falls back to search — it can
# find LinkedIn URLs but NOT emails (the tool does not pattern-guess).
APOLLO_API_KEY=
