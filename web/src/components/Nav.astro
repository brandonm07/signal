---
// Keep this in sync with BOOKING_URL in src/pages/index.astro
const BOOKING_URL = 'https://cal.com/signaladvisory';
---

<nav class="container mx-auto flex max-w-5xl items-center justify-between px-6 py-6 md:px-10">
  <a href="/" class="display text-xl font-medium">Signal Advisory</a>
  <ul class="hidden gap-8 text-sm md:flex">
    <li><a href="/#services" class="hover:text-signal">Services</a></li>
    <li><a href="/#about" class="hover:text-signal">About</a></li>
    <li><a href="/#contact" class="hover:text-signal">Contact</a></li>
  </ul>
  <a
    href={BOOKING_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="hidden rounded-sm bg-ink px-4 py-2 text-sm text-paper hover:bg-signal md:inline-block"
  >
    Book a free assessment
  </a>
</nav>
