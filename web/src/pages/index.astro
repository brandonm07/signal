---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

// Swap this for your real booking URL once Cal.com / Calendly is live.
const BOOKING_URL = 'https://cal.com/signaladvisory';

const ladder = [
  {
    step: '01',
    title: 'Free assessment',
    tier: 'No cost · 30 minutes',
    body: 'Bring us a current invoice, an upcoming renewal, or a technology problem you have not been able to solve. We tell you exactly what we see and what we would do. No obligation, no hard pitch.',
    cta: 'Start here',
  },
  {
    step: '02',
    title: 'Advisory',
    tier: 'Hourly or retained',
    body: 'Independent counsel on vendor selection, contract negotiation, architecture planning, and technology spend. We bring the expertise your team needs without the bias of a vendor relationship.',
  },
  {
    step: '03',
    title: 'Sourcing',
    tier: 'Engagement based',
    body: 'One advisor, every carrier evaluated. SD-WAN, UCaaS, dedicated internet, SASE, mobility — we assess the market, negotiate the terms, and recommend what actually fits your business.',
  },
  {
    step: '04',
    title: 'Lifecycle management',
    tier: 'Ongoing partnership',
    body: 'After the contract is signed: implementation oversight, vendor escalations, account management, invoice auditing, renewal strategy. Your team stays focused on the business. We manage the relationship.',
  },
];

const differentiators = [
  {
    title: 'Independent',
    body: 'We carry no carrier quota and represent no single vendor. Our recommendations are driven by your needs, not our commission structure.',
  },
  {
    title: 'Accountable',
    body: 'We stay on the account after the contract is signed. Implementation, provisioning, billing disputes, renewals — we are still at the table.',
  },
  {
    title: 'Experienced',
    body: 'Our principals come from inside the industry. We know how carriers price, where margin lives, and how to negotiate terms most advisors never ask for.',
  },
];
---

<Base>
  <Nav />

  <!-- Hero -->
  <section class="container mx-auto max-w-5xl px-6 pb-28 pt-20 md:px-10 md:pt-28">
    <p class="mb-5 text-xs uppercase tracking-[0.2em] text-stone">
      Independent technology advisory
    </p>
    <h1 class="display text-5xl font-light leading-[0.95] md:text-[5.5rem]">
      Better technology decisions.<br />
      <em class="text-signal not-italic font-medium">Measurable</em> results.
    </h1>
    <p class="mt-8 max-w-2xl text-lg leading-relaxed text-ink/75">
      Signal Advisory provides independent counsel on technology infrastructure — connectivity,
      cloud, security, and mobility. We evaluate every option on the market, negotiate on your
      behalf, and stay accountable to the outcome.
    </p>
    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href={BOOKING_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block rounded-sm bg-signal px-6 py-3 text-sm font-semibold text-paper hover:bg-ink transition-colors"
      >
        Book a free assessment
      </a>
      <a
        href="#services"
        class="inline-block rounded-sm border border-ink/20 px-6 py-3 text-sm font-medium hover:border-ink transition-colors"
      >
        What we do
      </a>
    </div>
  </section>

  <!-- Service ladder -->
  <section id="services" class="border-t border-ink/10 py-24">
    <div class="container mx-auto max-w-5xl px-6 md:px-10">
      <p class="mb-4 text-xs uppercase tracking-[0.2em] text-stone">How we work</p>
      <h2 class="display mb-6 max-w-3xl text-4xl font-normal leading-tight md:text-5xl">
        Start with a conversation. <em class="text-signal not-italic">Climb only as far as it serves you.</em>
      </h2>
      <p class="mb-14 max-w-2xl text-ink/70 leading-relaxed">
        Most clients begin with a free assessment and never need anything more. The
        ladder is here for the ones who do.
      </p>

      <ol class="grid gap-px bg-ink/10 md:grid-cols-2 lg:grid-cols-4">
        {
          ladder.map((s) => (
            <li class="flex flex-col bg-paper p-8">
              <div class="mb-6 flex items-baseline justify-between gap-4">
                <span class="display text-3xl font-medium text-signal">{s.step}</span>
                <span class="font-mono text-[10px] uppercase tracking-wider text-stone">
                  {s.tier}
                </span>
              </div>
              <h3 class="display mb-3 text-xl font-medium">{s.title}</h3>
              <p class="mb-6 text-[15px] leading-relaxed text-ink/70">{s.body}</p>
              {s.cta && (
                <a
                  href="#contact"
                  class="mt-auto inline-block self-start text-sm font-semibold text-signal hover:text-ink"
                >
                  {s.cta} →
                </a>
              )}
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Why Signal -->
  <section class="border-t border-ink/10 bg-ink py-24 text-paper">
    <div class="container mx-auto max-w-5xl px-6 md:px-10">
      <p class="mb-4 text-xs uppercase tracking-[0.2em] text-paper/40">Why Signal Advisory</p>
      <h2 class="display mb-4 max-w-3xl text-4xl font-normal leading-tight md:text-5xl">
        The counsel you would expect from a trusted partner.
      </h2>
      <p class="mb-16 max-w-2xl text-paper/60 text-lg leading-relaxed">
        Most technology vendors tell you what they sell. We tell you what you need — and we are
        structured so those two things are always the same answer.
      </p>
      <div class="grid gap-10 md:grid-cols-3">
        {
          differentiators.map((d) => (
            <div class="border-t border-paper/10 pt-8">
              <h3 class="display mb-4 text-xl font-medium">{d.title}</h3>
              <p class="text-paper/60 leading-relaxed text-[15px]">{d.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Approach -->
  <section id="about" class="border-t border-ink/10 py-24">
    <div class="container mx-auto max-w-5xl px-6 md:px-10">
      <div class="grid gap-16 md:grid-cols-2 md:items-center">
        <div>
          <p class="mb-4 text-xs uppercase tracking-[0.2em] text-stone">Our approach</p>
          <h2 class="display mb-6 text-4xl font-normal leading-tight md:text-5xl">
            We work for you.<br />Not the carrier.
          </h2>
          <p class="text-ink/70 leading-relaxed mb-6">
            Signal Advisory was built on a simple premise: organizations deserve honest technology
            counsel from advisors who have no stake in the outcome other than your satisfaction.
          </p>
          <p class="text-ink/70 leading-relaxed">
            Our principals spent over two decades inside the largest carriers and technology
            providers in the country. We know how the market works. We know where the leverage is.
            And we know how to use it for our clients — whether that is a ten-person company
            evaluating its first cloud phone system or a multi-site enterprise renegotiating a
            seven-figure infrastructure contract.
          </p>
        </div>
        <div class="grid gap-6">
          {[
            { num: '25+', label: 'Years of combined enterprise technology experience' },
            { num: '150+', label: 'Carriers and technology providers evaluated on your behalf' },
            { num: '3', label: 'Master agent partnerships for maximum carrier pricing leverage' },
          ].map((stat) => (
            <div class="border border-ink/10 p-8">
              <p class="display text-5xl font-medium text-signal mb-2">{stat.num}</p>
              <p class="text-ink/60 text-sm leading-relaxed">{stat.label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="border-t border-ink/10 bg-ink py-24 text-paper">
    <div class="container mx-auto max-w-3xl px-6 text-center md:px-10">
      <p class="mb-4 text-xs uppercase tracking-[0.2em] text-paper/40">Get started</p>
      <h2 class="display mb-6 text-4xl font-normal leading-tight md:text-5xl">
        A better technology decision starts with one conversation.
      </h2>
      <p class="mb-10 text-lg text-paper/60 leading-relaxed">
        Bring us your current contracts, your upcoming renewals, or simply a technology challenge
        you have not been able to solve. We will tell you exactly what we see and what we would do.
        No obligation.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href={BOOKING_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block rounded-sm bg-signal px-8 py-4 text-sm font-semibold text-paper hover:bg-paper hover:text-ink transition-colors"
        >
          Book a free assessment
        </a>
        <a
          href="mailto:hello@signaladvisory.com"
          class="inline-block rounded-sm border border-paper/20 px-8 py-4 text-sm font-medium text-paper hover:border-paper transition-colors"
        >
          hello@signaladvisory.com
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Base>
